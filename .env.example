# Server-side env vars for the /api/lead serverless function.
# Set these in Vercel → Project → Settings → Environment Variables.
# For local `vercel dev`, copy this file to `.env` and fill them in.
# (These are NOT VITE_ vars — they stay on the server, never in the browser.)

# Postgres connection string (Neon / Supabase / Railway / etc.) — required to store signups
DATABASE_URL=

# Optional email alerts on each signup (free via https://resend.com)
RESEND_API_KEY=
NOTIFY_EMAIL=
# Optional custom from-address (defaults to onboarding@resend.dev)
NOTIFY_FROM=

# "Ask AI" assistant — Gemini API key (https://aistudio.google.com/apikey)
# Required only if you want the AI assistant to give live answers.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=
